.container {
  background-color: #F2EFE6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
}

.result-paper {
  background: linear-gradient(to bottom, #FFFEF5, #FFF8E7);
  width: 100%;
  max-width: 600rpx;
  padding: 50rpx 40rpx;
  border-radius: 8rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.paper-fall {
  animation: paper-fall 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes paper-fall {
  0% { transform: translateY(-100vh) rotate(-5deg); opacity: 0; }
  60% { transform: translateY(10vh) rotate(2deg); opacity: 1; }
  80% { transform: translateY(-5vh) rotate(-1deg); }
  100% { transform: translateY(0) rotate(0deg); opacity: 1; }
}

.seal {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  border: 6rpx solid #C04851;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(192, 72, 81, 0.1);
  transform: rotate(-5deg);
}

.seal text {
  font-size: 40rpx;
  color: #C04851;
}

.seal-bounce {
  animation: seal-bounce 0.5s ease-out 0.8s forwards;
  opacity: 0;
}

@keyframes seal-bounce {
  0% { transform: scale(0) rotate(-15deg); }
  60% { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.gua-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.gua-label {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 4rpx;
}

.gua-fullname {
  font-size: 44rpx;
  color: #333;
  letter-spacing: 8rpx;
  display: block;
  margin-top: 10rpx;
}

.gua-symbols {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  gap: 8rpx;
}

.symbol-text {
  font-size: 36rpx;
  color: #333;
}

.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #C04851, transparent);
}

.divider-text {
  font-size: 24rpx;
}

.fortune-section {
  background: rgba(51, 51, 51, 0.05);
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.fortune-text {
  font-size: 32rpx;
  color: #333;
  font-style: italic;
  line-height: 1.6;
}

.numbers-section {
  margin-bottom: 40rpx;
}

.numbers-label {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 4rpx;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.balls-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.red-balls, .blue-balls {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.ball {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 32rpx;
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.3), inset 0 -3px 10rpx rgba(0, 0, 0, 0.2);
}

.ball-red {
  background: linear-gradient(145deg, #C04851, #8B0000);
}

.ball-blue {
  background: linear-gradient(145deg, #4A90D9, #1E4A8F);
}

.number-appear {
  animation: number-appear 0.4s ease-out forwards;
}

@keyframes number-appear {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 30rpx;
}

.btn-ghost {
  flex: 1;
  padding: 24rpx 0;
  background: transparent;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  letter-spacing: 4rpx;
}

.btn-ghost::after {
  border: none;
}

.copyright {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: #ccc;
}