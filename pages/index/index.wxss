.container {
    background-color: #F2EFE6;
    height: 100vh;
    display: flex;
    flex-direction: column;
}

.header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 60rpx;
}

.title {
    font-size: 56rpx;
    color: #333;
    letter-spacing: 8rpx;
    line-height: 1.4;
}

.font-xiaowei {
    font-family: 'ZCOOL XiaoWei', serif;
}

.subtitle {
    font-size: 24rpx;
    color: #999;
    margin-top: 12rpx;
    letter-spacing: 4rpx;
}

.lottery-selector {
    margin-top: 40rpx;
}

.segment-control {
    display: flex;
    gap: 60rpx;
}

.segment-item {
    font-size: 32rpx;
    color: #999;
    padding-bottom: 16rpx;
    position: relative;
    transition: all 0.3s ease;
}

.segment-item.active {
    color: #C04851;
}

.segment-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4rpx;
    background: #C04851;
}

.taiji-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
}

.taiji-btn {
    position: relative;
    width: 400rpx;
    height: 400rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.taiji-breath {
    animation: taiji-breathe 3s ease-in-out infinite;
}

@keyframes taiji-breathe {
    0%, 100% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.08); opacity: 1; }
}

.ink-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 50%;
    pointer-events: none;
}

.ink-drop {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 80rpx;
    height: 80rpx;
    background-color: rgba(51, 51, 51, 0.3);
    border-radius: 50%;
    opacity: 0;
}

.ink-drop.ink-spread {
    animation: ink-spread 1.5s ease-out forwards;
}

.taiji-svg {
    width: 380rpx;
    height: 380rpx;
}

.taiji-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    pointer-events: none;
}

.cinnabar-glow {
    animation: cinnabar-pulse 2s ease-in-out infinite;
}

@keyframes cinnabar-pulse {
    0%, 100% { box-shadow: 0 0 30rpx rgba(192, 72, 81, 0.3); }
    50% { box-shadow: 0 0 60rpx rgba(192, 72, 81, 0.6); }
}

.footer {
    text-align: center;
    padding-bottom: 40rpx;
}

.text-cinnabar {
    color: #C04851;
}

.hint-text {
    font-size: 32rpx;
    color: #C04851;
    letter-spacing: 4rpx;
}

.animate-pulse {
    animation: pulse 2s ease-in-out infinite;
}

.risk-text {
    margin-top: 30rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    font-size: 22rpx;
    color: #999;
    line-height: 1.6;
}

.risk-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.risk-modal.show {
    opacity: 1;
    pointer-events: auto;
}

.risk-modal-content {
    background: #F2EFE6;
    margin: 40rpx;
    padding: 50rpx 40rpx;
    border-radius: 20rpx;
    max-width: 600rpx;
    width: 100%;
}

.risk-modal-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    text-align: center;
    display: block;
    margin-bottom: 30rpx;
}

.risk-modal-body {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
    margin-bottom: 40rpx;
}

.risk-modal-body text {
    font-size: 26rpx;
    color: #666;
    line-height: 1.6;
}

.risk-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 16rpx;
    margin-bottom: 30rpx;
    cursor: pointer;
}

.risk-checkbox checkbox {
    margin-top: 6rpx;
}

.risk-checkbox text {
    font-size: 26rpx;
    color: #999;
}

.risk-confirm-btn {
    width: 100%;
    padding: 26rpx 0;
    background: #ccc;
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 12rpx;
    border: none;
    letter-spacing: 4rpx;
}

.risk-confirm-btn.active {
    background: #C04851;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

@keyframes ink-spread {
    0% {
        transform: translate(-50%, -50%) scale(0);
        opacity: 0.8;
    }
    50% {
        opacity: 0.4;
    }
    100% {
        transform: translate(-50%, -50%) scale(2);
        opacity: 0;
    }
}